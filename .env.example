# ─── Banco de Dados (Supabase PostgreSQL) ───────────────────────────────────
DATABASE_URL=postgresql://postgres:SUA_SENHA@db.SEU_PROJETO.supabase.co:5432/postgres

# ─── Fila (Upstash Redis) ────────────────────────────────────────────────────
REDIS_URL=rediss://default:SUA_SENHA@SEU_HOST.upstash.io:6379

# ─── WAHA (WhatsApp HTTP API) ────────────────────────────────────────────────
WAHA_BASE_URL=https://waha-SEU_APP.onrender.com
WAHA_API_KEY=waha-secret-key-2024

# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3000
APP_URL=https://disparos-SEU_APP.onrender.com

# ─── n8n Webhook (notificação ao finalizar campanha) ─────────────────────────
N8N_WEBHOOK_URL=https://n8n-SEU_APP.onrender.com/webhook/campanha-finalizada

# ─── Horário de envio (BRT) ──────────────────────────────────────────────────
ENVIO_HORA_INICIO=9
ENVIO_HORA_FIM=18
TZ=America/Sao_Paulo
